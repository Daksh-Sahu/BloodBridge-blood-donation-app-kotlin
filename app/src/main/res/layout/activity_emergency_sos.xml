<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF1F2">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#DC2626"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginBottom="5dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:paddingTop="20dp"
            android:src="@drawable/ic_arrow_back_new" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="35dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:fontFamily="serif"
            android:text="Emergency SOS"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Date Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_calendar"
                        android:contentDescription="Calendar" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Request Date"
                            android:textSize="12sp"
                            android:textColor="#6B7280" />

                        <TextView
                            android:id="@+id/currentDateText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monday, October 19, 2025"
                            android:textSize="14sp"
                            android:textColor="#1F2937" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Hospital Location Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_map_pin"
                            android:contentDescription="Location" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fetching Hospital Location"
                            android:textSize="16sp"
                            android:textColor="#1F2937"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>

                    <!-- Mock Map View -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="128dp"
                        android:background="@drawable/map_background">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_centerInParent="true"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_map_pin"
                                android:layout_marginBottom="4dp"
                                android:contentDescription="Hospital Location" />

                            <TextView
                                android:id="@+id/hospitalNameText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hospital name"
                                android:textSize="14sp"
                                android:textColor="#1F2937"
                                android:gravity="center" />

                            <TextView
                                android:id="@+id/hospitalCoordinatesText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lat: 40.7128, Lng: -74.0060"
                                android:textSize="12sp"
                                android:textColor="#6B7280"
                                android:gravity="center" />
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Emergency Request Form Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_alert_triangle"
                            android:contentDescription="Emergency" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Emergency Request Details"
                            android:textSize="16sp"
                            android:textColor="#1F2937"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>

                    <!-- Patient Name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="19dp"
                                android:contentDescription="User"
                                android:src="@drawable/ic_user" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Patient Name"
                                android:textSize="14sp"
                                android:textColor="#1F2937"
                                android:layout_marginStart="8dp" />
                        </LinearLayout>

                        <EditText
                            android:id="@+id/patientNameInput"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Enter patient's full name"
                            android:textSize="14sp"
                            android:padding="12dp"
                            android:background="@drawable/input_background"
                            android:inputType="textPersonName" />

                        <TextView
                            android:id="@+id/patientNameError"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#DC2626"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- Blood Type -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_droplet"
                                android:contentDescription="Blood Type" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Patient Blood Type"
                                android:textSize="14sp"
                                android:textColor="#1F2937"
                                android:layout_marginStart="8dp" />
                        </LinearLayout>

                        <Spinner
                            android:id="@+id/bloodTypeSpinner"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/input_background"
                            android:padding="12dp" /><!--spinner_background-->

                        <TextView
                            android:id="@+id/bloodTypeError"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#DC2626"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- Units Required -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_hash"
                                android:contentDescription="Units" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Units Required"
                                android:textSize="14sp"
                                android:textColor="#1F2937"
                                android:layout_marginStart="8dp" />
                        </LinearLayout>

                        <EditText
                            android:id="@+id/unitsRequiredInput"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Enter number of units needed"
                            android:textSize="14sp"
                            android:padding="12dp"
                            android:background="@drawable/input_background"
                            android:inputType="number" />

                        <TextView
                            android:id="@+id/unitsRequiredError"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#DC2626"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- Patient Age -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp">

                        <!-- Label Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp"
                            android:layout_marginStart="8dp">

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_marginEnd="6dp"
                                android:src="@drawable/ic_user"
                                android:contentDescription="Patient Age Icon" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Patient Age"
                                android:textColor="#1F2937"
                                android:textSize="14sp"
                                 />
                        </LinearLayout>

                        <!-- Input Field -->
                        <EditText
                            android:id="@+id/patientAgeInput"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Enter patient age"
                            android:textSize="14sp"
                            android:padding="12dp"
                            android:background="@drawable/input_background"
                            android:inputType="number"
                            android:maxLength="3" />

                        <!-- Error Text -->
                        <TextView
                            android:id="@+id/patientAgeError"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#DC2626"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"
                            android:visibility="gone" />
                    </LinearLayout>



                    <!-- Contact Person Number -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_phone_new"
                                android:contentDescription="Phone" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Contact Number"
                                android:textSize="14sp"
                                android:textColor="#1F2937"
                                android:layout_marginStart="8dp" />
                        </LinearLayout>

                        <EditText
                            android:id="@+id/contactPersonNumberInput"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Enter 10-digit phone number"
                            android:textSize="14sp"
                            android:padding="12dp"
                            android:background="@drawable/input_background"
                            android:inputType="phone"
                            android:maxLength="10" />

                        <TextView
                            android:id="@+id/contactPersonNumberError"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#DC2626"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Submit Button -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/postRequestButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/emergency_button_background"
                    android:drawableLeft="@drawable/ic_alert_triangle"
                    android:drawablePadding="8dp"
                    android:drawableTint="@android:color/white"
                    android:gravity="center"
                    android:text="Post Emergency Request"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:layout_marginBottom="35dp"/>

                <ProgressBar
                    android:id="@+id/loadingProgress"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerInParent="true"
                    android:visibility="gone"
                    android:indeterminateTint="@android:color/white"
                    />
            </RelativeLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
