<!-- button_secondary.xml -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/bg_red_50" />
            <corners android:radius="@dimen/radius_md" />
            <stroke
                android:width="1dp"
                android:color="@color/primary_red" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/white" />
            <corners android:radius="@dimen/radius_md" />
            <stroke
                android:width="1dp"
                android:color="@color/primary_red" />
        </shape>
    </item>
</selector>