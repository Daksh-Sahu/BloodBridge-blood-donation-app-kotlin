<!-- button_primary.xml -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/primary_red_dark" />
            <corners android:radius="@dimen/radius_xl" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/primary_red" />
            <corners android:radius="@dimen/radius_xl" />
        </shape>
    </item>
</selector>